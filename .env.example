# Copia este archivo a .env.local para desarrollo, y configura las mismas
# variables en Vercel -> Settings -> Environment Variables para produccion.

# Login con Microsoft 365 (reutiliza la misma App Registration de Entra ID
# que usa postular.pertec.cl, agregandole el redirect URI de core.pertec.cl)
AUTH_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# Supabase (proyecto dedicado core-pertec)
NEXT_PUBLIC_SUPABASE_URL=https://fwvdztxxkbzxsqpqgvvg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supabase de pertec-web (proyecto rvtmrzjlxovowszxmhoy): /proyectos lee y
# escribe ahi directo, sin migrar la data del panel original. La key se
# obtiene en supabase.com/dashboard -> ese proyecto -> Settings -> API ->
# service_role (NO la publishable/anon).
PERTEC_WEB_SUPABASE_URL=https://rvtmrzjlxovowszxmhoy.supabase.co
PERTEC_WEB_SUPABASE_SERVICE_ROLE_KEY=

# Microsoft Graph (app-only) para leer postulaciones de SharePoint en /reclutamiento.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_SITE_ID=

# Microsoft Graph para enviar correo (usado por /finanzas para avisar fallos
# a soporte@pertec.cl). Es el app registration "PERTEC Web - Envio de
# correos" (mismo que usa la Edge Function send-catalog de pertec-web),
# que ya tiene el permiso de aplicacion Mail.Send concedido - no reutilizar
# las variables AZURE_* de arriba, ese app solo tiene permisos de SharePoint.
MS_TENANT_ID=
MS_CLIENT_ID=6f8ce670-8b60-471a-aa01-d33cd280a453
MS_CLIENT_SECRET=

# Panel Finanzas: credenciales del SII para el scraper del Registro de
# Compras y Ventas (RUT del representante legal, no el de la empresa).
SII_RUT_REPRESENTANTE=
SII_CLAVE_TRIBUTARIA=
SII_RUT_EMPRESA=77590967-6

# Secreto que protege /api/cron/finanzas-sii, /api/cron/finanzas-historico y
# /api/cron/panel-odoo. Vercel Cron lo envia solo si esta variable esta
# configurada en el proyecto (Authorization: Bearer ...); el workflow de
# GitHub Actions que sincroniza Panel Odoo (.github/workflows/panel-odoo-sync.yml)
# necesita el MISMO valor guardado como secret en GitHub -> Settings ->
# Secrets and variables -> Actions -> CRON_SECRET.
CRON_SECRET=

# Panel Odoo: credenciales de un usuario administrador global de Odoo (JSON-RPC
# de solo lectura, ver lib/panel-odoo/odoo-cliente.ts). ODOO_URL es la base
# del sitio Odoo.sh (sin /jsonrpc al final); ODOO_DB es el nombre interno de
# la base de datos (visible en el dashboard de Odoo.sh); ODOO_API_KEY se
# genera en Odoo -> Ajustes -> Usuarios -> ese usuario -> Claves API.
ODOO_URL=
ODOO_DB=
ODOO_LOGIN=
ODOO_API_KEY=

# Panel "Facturas Historicas": mismo AZURE_TENANT_ID/CLIENT_ID/CLIENT_SECRET
# de arriba (Microsoft Graph app-only), pero apuntando a OTRO sitio de
# SharePoint (el de Finanzas, no el de postular.pertec.cl). Ese sitio
# necesita el permiso Sites.Selected concedido por separado -- ver
# README.md, seccion "Facturas Historicas (SharePoint)", paso que debe
# ejecutar un administrador del sitio a mano (no lo hace la app).
# Acepta el formato de direccionamiento por ruta de Graph, para no tener que
# resolver el GUID del sitio: "<host>.sharepoint.com:/sites/<NombreSitio>".
SHAREPOINT_FACTURAS_SITE_ID=performancecl.sharepoint.com:/sites/FINANZASPERTEC
